---
export interface Props {
  dateDisplay: string;
  sortDate?:   string;
  venue:       string;
  city:        string;
  country:     string;
  note?:       string;
  ticketUrl?:  string;
  past?:       boolean;
}

const { dateDisplay, sortDate, venue, city, country, note, ticketUrl, past = false } = Astro.props;
---

<div class:list={['show-row', { 'show-row--past': past }]} data-sort-date={sortDate}>
  <div class="show-date">
    <span class="date-text">{dateDisplay}</span>
    {note && <span class="show-note">{note}</span>}
  </div>

  <div class="show-details">
    <span class="show-venue">{venue}</span>
    <span class="show-city">{city}</span>
    <span class="show-country">{country}</span>
  </div>

  <div class="show-ticket">
    {ticketUrl && !past && (
      <a href={ticketUrl} target="_blank" rel="noopener" class="ticket-link">Tickets</a>
    )}
  </div>
</div>

<style>
  .show-row {
    display: grid;
    grid-template-columns: 160px 1fr 90px;
    gap: 16px;
    align-items: center;
    padding: 18px 0;
    border-bottom: 1px solid #D4C9BE;
  }

  .show-row--past {
    opacity: 0.45;
  }

  /* Date column */
  .show-date {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .date-text {
    font-family: 'Caveat', cursive;
    font-size: 22px;
    color: #2A2420;
    line-height: 1.1;
  }

  .show-note {
    font-family: 'Lora', serif;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #C73B72;
  }

  /* Details column */
  .show-details {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .show-venue {
    font-family: 'Lora', serif;
    font-size: 18px;
    color: #2A2420;
    line-height: 1.2;
  }

  .show-city {
    font-family: 'Lora', serif;
    font-size: 14px;
    color: #6B5D54;
  }

  .show-country {
    font-family: 'Caveat', cursive;
    font-size: 18px;
    color: #74C3E1;
    line-height: 1.1;
  }

  /* Ticket column */
  .show-ticket {
    display: flex;
    justify-content: flex-end;
  }

  .ticket-link {
    font-family: 'Lora', serif;
    font-size: 13px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #C73B72;
    text-decoration: none;
    border: 1.5px solid #C73B72;
    padding: 6px 14px;
    transition: background 0.2s, color 0.2s;
    white-space: nowrap;
  }

  .ticket-link:hover {
    background: #C73B72;
    color: #fff;
  }

  @media (max-width: 640px) {
    .show-row {
      grid-template-columns: 1fr auto;
      grid-template-rows: auto auto;
    }

    .show-date { grid-column: 1; }
    .show-details { grid-column: 1; }
    .show-ticket { grid-column: 2; grid-row: 1 / 3; align-self: center; }
  }
</style>
